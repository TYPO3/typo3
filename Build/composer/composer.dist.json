{
	"name": "typo3/test-distribution",
	"type": "typo3-cms-distribution",
	"description": "For testing Composer installation",
	"version": "1.0.0",
	"config": {
		"allow-plugins": {
			"composer/package-versions-deprecated": true,
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		}
	},
	"repositories": [
		{
			"type": "path",
			"url": "../../typo3/sysext/*",
			"options": {
				"versions": {
					"typo3/cms-backend": "15.0.0-dev",
					"typo3/cms-core": "15.0.0-dev",
					"typo3/cms-extbase": "15.0.0-dev",
					"typo3/cms-extensionmanager": "15.0.0-dev",
					"typo3/cms-filelist": "15.0.0-dev",
					"typo3/cms-fluid": "15.0.0-dev",
					"typo3/cms-frontend": "15.0.0-dev",
					"typo3/cms-install": "15.0.0-dev",
					"typo3/cms-adminpanel": "15.0.0-dev",
					"typo3/cms-belog": "15.0.0-dev",
					"typo3/cms-beuser": "15.0.0-dev",
					"typo3/cms-dashboard": "15.0.0-dev",
					"typo3/cms-felogin": "15.0.0-dev",
					"typo3/cms-filemetadata": "15.0.0-dev",
					"typo3/cms-fluid-styled-content": "15.0.0-dev",
					"typo3/cms-form": "15.0.0-dev",
					"typo3/cms-impexp": "15.0.0-dev",
					"typo3/cms-indexed-search": "15.0.0-dev",
					"typo3/cms-info": "15.0.0-dev",
					"typo3/cms-linkvalidator": "15.0.0-dev",
					"typo3/cms-lowlevel": "15.0.0-dev",
					"typo3/cms-opendocs": "15.0.0-dev",
					"typo3/cms-reactions": "15.0.0-dev",
					"typo3/cms-recycler": "15.0.0-dev",
					"typo3/cms-redirects": "15.0.0-dev",
					"typo3/cms-reports": "15.0.0-dev",
					"typo3/cms-rte-ckeditor": "15.0.0-dev",
					"typo3/cms-scheduler": "15.0.0-dev",
					"typo3/cms-seo": "15.0.0-dev",
					"typo3/cms-setup": "15.0.0-dev",
					"typo3/cms-styleguide": "15.0.0-dev",
					"typo3/cms-sys-note": "15.0.0-dev",
					"typo3/cms-t3editor": "15.0.0-dev",
					"typo3/cms-tstemplate": "15.0.0-dev",
					"typo3/cms-viewpage": "15.0.0-dev",
					"typo3/cms-webhooks": "15.0.0-dev",
					"typo3/cms-workspaces": "15.0.0-dev",
					"typo3/theme-camino": "15.0.0-dev"
				}
			}
		},
		{
			"type": "path",
			"url": "packages/*"
		}
	],
	"require": {
		"typo3/cms-backend": "@dev",
		"typo3/cms-core": "@dev",
		"typo3/cms-extbase": "@dev",
		"typo3/cms-extensionmanager": "@dev",
		"typo3/cms-filelist": "@dev",
		"typo3/cms-fluid": "@dev",
		"typo3/cms-frontend": "@dev",
		"typo3/cms-install": "@dev",
		"typo3/cms-adminpanel": "@dev",
		"typo3/cms-belog": "@dev",
		"typo3/cms-beuser": "@dev",
		"typo3/cms-dashboard": "@dev",
		"typo3/cms-felogin": "@dev",
		"typo3/cms-filemetadata": "@dev",
		"typo3/cms-fluid-styled-content": "@dev",
		"typo3/cms-form": "@dev",
		"typo3/cms-impexp": "@dev",
		"typo3/cms-indexed-search": "@dev",
		"typo3/cms-info": "@dev",
		"typo3/cms-linkvalidator": "@dev",
		"typo3/cms-lowlevel": "@dev",
		"typo3/cms-opendocs": "@dev",
		"typo3/cms-reactions": "@dev",
		"typo3/cms-recycler": "@dev",
		"typo3/cms-redirects": "@dev",
		"typo3/cms-reports": "@dev",
		"typo3/cms-rte-ckeditor": "@dev",
		"typo3/cms-scheduler": "@dev",
		"typo3/cms-seo": "@dev",
		"typo3/cms-setup": "@dev",
		"typo3/cms-styleguide": "@dev",
		"typo3/cms-sys-note": "@dev",
		"typo3/cms-t3editor": "@dev",
		"typo3/cms-tstemplate": "@dev",
		"typo3/cms-viewpage": "@dev",
		"typo3/cms-webhooks": "@dev",
		"typo3/cms-workspaces": "@dev",
		"typo3/theme-camino": "@dev"
	}
}
