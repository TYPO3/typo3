        <source>There are no open documents available to edit.</source>
        <target state="final">бһҳбһ·бһ“вҖӢбһҳбһ¶бһ“вҖӢбһҜбһҖбһҹбһ¶бһҡвҖӢбһҺбһ¶вҖӢбһ”бһҫбһҖвҖӢвҖӢбһҠбҹӮбһӣвҖӢбһўбһ¶бһ…вҖӢбһҖбҹӮвҖӢбһ”бһ¶бһ“вҖӢбһ‘бҹҒ бҹ”</target>
      </trans-unit>
      <trans-unit id="noDocuments_msg2" approved="yes">
        <source>You can go to %s to find the page or the record you wish to edit.</source>
        <target state="final">бһўбҹ’бһ“бһҖвҖӢбһўбһ¶бһ…вҖӢбһ…бһјбһӣвҖӢбһ‘бҹ… %s бһҠбһҫбһҳбҹ’бһ”бһёвҖӢбһҡбһҖвҖӢбһ‘бҹҶбһ–бҹҗбһҡ бһ¬вҖӢбһ‘бһ·бһ“бҹ’бһ“бһ“бҹҗбһҷвҖӢбһҠбҹӮбһӣвҖӢбһҸбҹ’бһҡбһјбһңбһҖбһ¶бһҡвҖӢбһҖбҹӮ бҹ”</target>
      </trans-unit>
      <trans-unit id="noDocuments_pagemodule" x-unused-since="14.0" approved="yes">
        <source>the Web&gt;Page module</source>
        <target state="final">бһҳбҹүбһјбһҢбһ»бһӣ бһңбҹӮбһ”&gt;бһ‘бҹҶбһ–бҹҗбһҡ</target>
      </trans-unit>
      <trans-unit id="noDocuments_OR" approved="yes">
        <source>or</source>
        <target state="final">бһ¬</target>
      </trans-unit>
      <trans-unit id="noDocuments_listmodule" x-unused-since="14.0" approved="yes">
        <source>the Web&gt;List module</source>
        <target state="final">бһҳбҹүбһјбһҢбһ»бһӣ бһңбҹӮбһ”&gt;бһ”бһүбҹ’бһҮбһё</target>
      </trans-unit>
