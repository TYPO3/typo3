        <source>Are you sure you want to delete this record?</source>
        <target state="final">бһҸбһҫвҖӢбһўбҹ’бһ“бһҖвҖӢбһ–бһ·бһҸвҖӢбһҮбһ¶вҖӢбһ…бһ„бҹӢвҖӢбһӣбһ»бһ”вҖӢбһ‘бһ·бһ“бҹ’бһ“бһ“бҹҗбһҷвҖӢбһ“бҹҒбҹҮвҖӢбһҳбҹӮбһ“вҖӢбһ‘бҹҒ?</target>
      </trans-unit>
      <trans-unit id="undoLastChange" approved="yes">
        <source>Undo/Redo last change (%s ago)</source>
        <target state="final">бһҳбһ·бһ“вҖӢбһ’бҹ’бһңбһҫвҖӢбһңбһ·бһү/вҖӢбһ’бҹ’бһңбһҫвҖӢбһЎбһҫбһ„вҖӢбһңбһ·бһүвҖӢбһ“бһјбһңвҖӢбһҖбһ¶бһҡбһ•бҹ’бһӣбһ¶бһҹбҹӢбһ”бҹ’бһҠбһјбһҡвҖӢбһ…бһ»бһ„бһҖбҹ’бһҡбҹ„бһҷ (%s бһҳбһ»бһ“)</target>
      </trans-unit>
