        <target state="final">бһҳбһҫбһӣвҖӢбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·вҖӢбһ“бҹғвҖӢбһҖбһ¶бһҡбһ•бҹ’бһӣбһ¶бһҹбҹӢбһ”бҹ’бһҠбһјбһҡвҖӢбһ‘бҹҶбһ–бҹҗбһҡ</target>
      </trans-unit>
      <trans-unit id="editWholeRecord" approved="yes">
        <source>Edit whole record</source>
        <target state="final">бһҖбҹӮвҖӢбһ‘бһ·бһ“бҹ’бһ“бһ“бҹҗбһҷвҖӢбһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢ</target>
      </trans-unit>
      <trans-unit id="openDocs" approved="yes">
        <source>OPEN DOCUMENTS</source>
        <target state="final">бһ”бһҫбһҖвҖӢбһҜбһҖбһҹбһ¶бһҡ</target>
      </trans-unit>
      <trans-unit id="noDocuments" approved="yes">
        <source>No open documents</source>
        <target state="final">бһҳбһ·бһ“вҖӢбһҳбһ¶бһ“вҖӢбһҜбһҖбһҹбһ¶бһҡвҖӢбһҖбҹҶбһ–бһ»бһ„вҖӢбһ”бһҫбһҖ</target>
      </trans-unit>
