      </trans-unit>
      <trans-unit id="localize.view.summary" approved="yes">
        <source>Record summary</source>
        <target state="final">Element-resumé</target>
      </trans-unit>
      <trans-unit id="localize.view.processing" approved="yes">
        <source>Processing...</source>
