<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" version="1.2">
  <file source-language="en" datatype="plaintext" original="EXT:backend/Resources/Private/Language/locallang_alt_doc.xlf" date="2011-10-17T20:22:33Z" product-name="lang" target-language="ru">
    <header/>
    <body>
      <trans-unit id="deleteItem" approved="yes">
        <source>Delete</source>
        <target state="final">Удалить</target>
      </trans-unit>
      <trans-unit id="deleteWarning" approved="yes">
        <source>Are you sure you want to delete this record?</source>
        <target state="final">Действительно удалить эту запись?</target>
      </trans-unit>
      <trans-unit id="undoLastChange" approved="yes">
        <source>Undo/Redo last change (%s ago)</source>
        <target state="final">Отменить/Восстановить последние изменения (%s шагов)</target>
      </trans-unit>
      <trans-unit id="recordHistory" approved="yes">
        <source>View record change history</source>
        <target state="final">Показать историю изменения записи</target>
      </trans-unit>
      <trans-unit id="editWholeRecord" approved="yes">
        <source>Edit whole record</source>
        <target state="final">Редактировать всю запись</target>
      </trans-unit>
      <trans-unit id="openDocs" approved="yes">
        <source>OPEN DOCUMENTS</source>
        <target state="final">ОТКРЫТЫЕ ДОКУМЕНТЫ</target>
      </trans-unit>
      <trans-unit id="noDocuments" approved="yes">
        <source>No open documents</source>
        <target state="final">Открытых документов нет</target>
      </trans-unit>
      <trans-unit id="noDocuments_msg" approved="yes">
        <source>There are no open documents available to edit.</source>
        <target state="final">Нет открытых документов, доступных для редактирования.</target>
      </trans-unit>
      <trans-unit id="noDocuments_msg2" approved="yes">
        <source>You can go to %s to find the page or the record you wish to edit.</source>
        <target state="final">Идите в %s, чтобы найти страницу или запись, которую вы хотите изменить.</target>
      </trans-unit>
      <trans-unit id="noDocuments_msg3" approved="yes">
        <source>You can select one of your most recently edited records from this list</source>
        <target state="final">В списке можно выбрать одну из часто редактируемых записей</target>
      </trans-unit>
      <trans-unit id="noDocuments_pagemodule" x-unused-since="14.0" approved="yes">
        <source>the Web&gt;Page module</source>
        <target state="final">модуль Веб&gt;Страница</target>
      </trans-unit>
      <trans-unit id="noDocuments_OR" approved="yes">
        <source>or</source>
        <target state="final">или</target>
      </trans-unit>
      <trans-unit id="noDocuments_listmodule" x-unused-since="14.0" approved="yes">
        <source>the Web&gt;List module</source>
        <target state="final">модуль Веб&gt;Список</target>
      </trans-unit>
      <trans-unit id="noEditForm" approved="yes">
        <source>Edit form could not be loaded</source>
        <target state="final">Не удалось загрузить форму редактирования</target>
      </trans-unit>
      <trans-unit id="noEditForm.message" approved="yes">
        <source>The edit form could not be loaded for the requested records. This might be due to insufficient permissions.</source>
        <target state="final">Невозможно загрузить форму редактирования для запрошенных записей. Возможно недостаточно прав.</target>
      </trans-unit>
      <trans-unit id="noFieldsEditForm" approved="yes">
        <source>No fields to edit</source>
        <target state="final">Отстутствуют поля для редактирования</target>
      </trans-unit>
      <trans-unit id="noFieldsEditForm.message" approved="yes">
        <source>There are no editable fields available for the requested record. This might be due to insufficient permissions or a configuration mismatch.</source>
        <target state="final">Отсутствуют доступные для редактирования поля для запрошенной записи. Причиной может быть отсутствие прав доступа или несоответствие конфигурации.</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.duplicate_record_changed.cancel" approved="yes">
        <source>Cancel</source>
        <target state="final">Отмена</target>
      </trans-unit>
      <trans-unit id="button.confirm.duplicate_record_changed.no" approved="yes">
        <source>No, just duplicate the original</source>
        <target state="final">Нет, просто дублировать оригинал</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.duplicate_record_changed.yes" approved="yes">
        <source>Yes, save and duplicate this record</source>
        <target state="final">Да, сохранить и дублировать эту запись</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.close_without_save.yes" approved="yes">
        <source>Discard changes</source>
        <target state="final">Отменить изменения</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.close_without_save.no" approved="yes">
        <source>Keep editing</source>
        <target state="final">Продолжить редактирование</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.save_and_close" approved="yes">
        <source>Save and close</source>
        <target state="final">Сохранить и закрыть</target>
      </trans-unit>
      <trans-unit id="label.confirm.duplicate_record_changed.title" approved="yes">
        <source>Do you want to save before duplicating this record?</source>
        <target state="final">Сохранить изменения перед дублированием записи?</target>
      </trans-unit>
      <trans-unit id="label.confirm.duplicate_record_changed.content" approved="yes">
        <source>You currently have unsaved changes. Do you want to save your changes before duplicating this record?</source>
        <target state="final">Есть несохраненные изменения. Сохранить изменения перед копированием этой записи?</target>
      </trans-unit>
      <trans-unit id="label.confirm.new_record_changed.title" approved="yes">
        <source>Do you want to save before adding?</source>
        <target state="final">Сохранить перед добавлением?</target>
      </trans-unit>
      <trans-unit id="label.confirm.new_record_changed.content" approved="yes">
        <source>You need to save your changes before creating a new record. Do you want to save and create now?</source>
        <target state="final">Вам необходимо сохранить изменения перед созданием новой записи. Сохранить и создать новую запись?</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.new_record_changed.cancel" approved="yes">
        <source>Cancel</source>
        <target state="final">Отмена</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.new_record_changed.no" approved="yes">
        <source>No, just add</source>
        <target state="final">Нет, просто добавить</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.new_record_changed.yes" approved="yes">
        <source>Yes, save and create now</source>
        <target state="final">Да, сохранить и создать</target>
      </trans-unit>
      <trans-unit id="label.confirm.view_record_changed.title" approved="yes">
        <source>Do you want to save before viewing?</source>
        <target state="final">Сохранить перед просмотром?</target>
      </trans-unit>
      <trans-unit id="label.confirm.view_record_changed.content" approved="yes">
        <source>You currently have unsaved changes. You can either discard these changes or save and view them.</source>
        <target state="final">Есть несохраненные изменения. Можно отменить эти изменения или сохранить и просмотреть их.</target>
      </trans-unit>
      <trans-unit id="label.confirm.view_record_changed.invalid_form" approved="yes">
        <source>The form appears to be invalid, therefore "Save changes and view" is not available.</source>
        <target state="final">Похоже, что форма некорректна, поэтому функция "Сохранить изменения и просмотреть" недоступна.</target>
      </trans-unit>
      <trans-unit id="label.confirm.view_record_changed.content.is-new-page" approved="yes">
        <source>You need to save your changes before viewing the page. Do you want to save and view them now?</source>
        <target state="final">Необходимо сохранить изменения перед просмотром страницы. Сохранить и вывести страницу?</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.view_record_changed.cancel" approved="yes">
        <source>Cancel</source>
        <target state="final">Отмена</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.view_record_changed.no-save" approved="yes">
        <source>View without changes</source>
        <target state="final">Просмотр без изменений</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.view_record_changed.save" approved="yes">
        <source>Save changes and view</source>
        <target state="final">Сохранить изменения и просмотреть</target>
      </trans-unit>
      <trans-unit id="label.confirm.close_without_save.title" approved="yes">
        <source>Unsaved changes</source>
        <target state="final">Несохраненные изменения</target>
      </trans-unit>
      <trans-unit id="label.confirm.close_without_save.content" approved="yes">
        <source>You currently have unsaved changes which will be discarded if you close without saving.</source>
        <target state="final">Имеются несохраненные изменения, которые будут удалены при закрытии без сохранения.</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.delete_file.no" approved="yes">
        <source>Cancel</source>
        <target state="final">Отмена</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.delete_file.yes" approved="yes">
        <source>Yes, delete this file</source>
        <target state="final">Да, удалить этот файл</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.delete_folder.yes" approved="yes">
        <source>Yes, delete this folder</source>
        <target state="final">Да, удалить папку</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.delete_record.no" approved="yes">
        <source>Cancel</source>
        <target state="final">Отмена</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.delete_record.yes" approved="yes">
        <source>Delete</source>
        <target state="final">Удалить</target>
      </trans-unit>
      <trans-unit id="label.confirm.delete_record.title" approved="yes">
        <source>Delete this record?</source>
        <target state="final">Удалить эту запись?</target>
      </trans-unit>
      <trans-unit id="label.confirm.delete_record.content" approved="yes">
        <source>Are you sure you want to delete the record '%s'?</source>
        <target state="final">Подтверждаете удаление записи '%s'?</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.delete_elements.no" approved="yes">
        <source>Cancel</source>
        <target state="final">Отмена</target>
      </trans-unit>
      <trans-unit id="buttons.confirm.delete_elements.yes" approved="yes">
        <source>Yes, delete these elements</source>
        <target state="final">Да, удалить эти элементы</target>
      </trans-unit>
      <trans-unit id="label.alert.save_with_error.title" approved="yes">
        <source>You have errors in your form!</source>
        <target state="final">В вашей форме есть ошибки!</target>
      </trans-unit>
      <trans-unit id="label.alert.save_with_error.content" approved="yes">
        <source>Please check the form, there is at least one error in your form.</source>
        <target state="final">Пожалуйста, проверьте форму, в ней есть как минимум одна ошибка.</target>
      </trans-unit>
      <trans-unit id="buttons.alert.save_with_error.ok" approved="yes">
        <source>OK</source>
        <target state="final">Да</target>
      </trans-unit>
      <trans-unit id="buttons.reviewFailedValidationFields" approved="yes">
        <source>Review fields with failed validations</source>
        <target state="final">Просмотр полей не прошедших проверку</target>
      </trans-unit>
      <trans-unit id="buttons.pageTsConfig" approved="yes">
        <source>PageTS Config</source>
        <target state="final">Настройка PageTS</target>
      </trans-unit>
      <trans-unit id="notification.record_saved.title.singular" approved="yes">
        <source>Record saved</source>
        <target state="final">Запись сохранена</target>
      </trans-unit>
      <trans-unit id="notification.record_saved.title.plural" approved="yes">
        <source>Records saved</source>
        <target state="final">Записи сохранены</target>
      </trans-unit>
      <trans-unit id="notification.record_saved.message" approved="yes">
        <source>Record "%s" has been successfully saved.</source>
        <target state="final">Запись "%s" успешно сохранена.</target>
      </trans-unit>
      <trans-unit id="notification.mass_saving.message" approved="yes">
        <source>%s records have been successfully saved.</source>
        <target state="final">%s записи были успешно сохранены.</target>
      </trans-unit>
      <trans-unit id="search.find_record" approved="yes">
        <source>Find records</source>
        <target state="final">Найти записи</target>
      </trans-unit>
      <trans-unit id="search.no_records_found" approved="yes">
        <source>No records found</source>
        <target state="final">Записей не найдено</target>
      </trans-unit>
      <trans-unit id="flexform.section.delete.title" approved="yes">
        <source>Delete this container?</source>
        <target state="final">Удалить этот контейнер?</target>
      </trans-unit>
      <trans-unit id="flexform.section.delete.message" approved="yes">
        <source>Are you sure you want to delete this container?</source>
        <target state="final">Подтвердите удаление этого контейнера</target>
      </trans-unit>
      <trans-unit id="tcatree.findItem" approved="yes">
        <source>Filter by item</source>
        <target state="final">Фильтр по элементу</target>
      </trans-unit>
      <trans-unit id="tcatree.expandAll" approved="yes">
        <source>Expand all</source>
        <target state="final">Развернуть все</target>
      </trans-unit>
      <trans-unit id="tcatree.collapseAll" approved="yes">
        <source>Collapse all</source>
        <target state="final">Свернуть все</target>
      </trans-unit>
      <trans-unit id="tcatree.toggleHideUnchecked" approved="yes">
        <source>Toggle hide unchecked</source>
        <target state="final">Снять флажок скрытия</target>
      </trans-unit>
    </body>
  </file>
